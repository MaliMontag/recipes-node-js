{
  "info": {
    "name": "Recipes API",
    "_postman_id": "0b4f9fc0-9f9c-4ec2-af55-a9987f9b4823",
    "description": "Collection for Recipes RESTful API project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "recipeCode", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"StrongP@ss1\",\n  \"address\": \"Tel Aviv\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"StrongP@ss1\"\n}"
        }
      }
    },
    {
      "name": "Users - Get All",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Recipes - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/recipes?search=&limit=5&page=1"
      }
    },
    {
      "name": "Recipes - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/recipes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pasta Alfredo\",\n  \"description\": \"Creamy pasta recipe\",\n  \"categoryCodes\": [\"DINNER\"],\n  \"prepTimeMinutes\": 25,\n  \"difficulty\": 2,\n  \"image\": \"\",\n  \"layers\": [\n    {\n      \"description\": \"Main\",\n      \"ingredients\": [\"Pasta\", \"Cream\", \"Cheese\"]\n    }\n  ],\n  \"isPrivate\": false\n}"
        }
      }
    },
    {
      "name": "Recipes - By Code",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/recipes/{{recipeCode}}"
      }
    },
    {
      "name": "Recipes - By Prep Time",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/recipes/prep-time/30"
      }
    },
    {
      "name": "Categories - All",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/categories"
      }
    },
    {
      "name": "Categories - With Recipes",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/categories/with-recipes"
      }
    }
  ]
}
